{
  "skill_defs": {
    "nano": {
      "name": "Nanotech",
      "icon": "🔬",
      "color": "#44ff88",
      "type": "combat",
      "desc": "Close-range melee combat using nano-swarm blades. Strong vs Tesla, weak vs Void.",
      "trains": "Kill enemies while using Nano combat style.",
      "category": "Combat",
      "needs": ["circuitry", "bioforge"],
      "feedDesc": "Equip Circuitry weapons + Bioforge armor to fight stronger enemies"
    },
    "tesla": {
      "name": "Tesla",
      "icon": "⚡",
      "color": "#44aaff",
      "type": "combat",
      "desc": "Mid-range electrical attacks with coilguns. Strong vs Void, weak vs Nano.",
      "trains": "Kill enemies while using Tesla combat style.",
      "category": "Combat",
      "needs": ["circuitry", "bioforge"],
      "feedDesc": "Equip Circuitry weapons + Bioforge armor to fight stronger enemies"
    },
    "void": {
      "name": "Void",
      "icon": "🌀",
      "color": "#aa44ff",
      "type": "combat",
      "desc": "Long-range dark energy from voidstaffs. Strong vs Nano, weak vs Tesla.",
      "trains": "Kill enemies while using Void combat style.",
      "category": "Combat",
      "needs": ["circuitry", "bioforge"],
      "feedDesc": "Equip Circuitry weapons + Bioforge armor to fight stronger enemies"
    },
    "astromining": {
      "name": "Astromining",
      "icon": "⛏️",
      "color": "#ff8844",
      "type": "gathering",
      "desc": "Extract ores and gems from asteroid deposits. Higher levels unlock rarer materials.",
      "trains": "Mine ore nodes in the Asteroid Mines.",
      "category": "Gathering",
      "feeds": ["circuitry", "chronomancy"],
      "feedDesc": "Ores feed into Circuitry for smelting. Star Dust and Temporal Dust fuel Chronomancy."
    },
    "xenobotany": {
      "name": "Xenobotany",
      "icon": "🌿",
      "color": "#66cc55",
      "type": "gathering",
      "desc": "Harvest alien flora — lichens, kelps, fruits, and chitin from the Gathering Grounds. Supplies ingredients for Xenocook and Bioforge.",
      "trains": "Gather bio-resources in the Gathering Grounds.",
      "category": "Gathering",
      "feeds": ["bioforge", "xenocook", "psionics"],
      "feedDesc": "Bio-resources feed Bioforge (armor/serums), Xenocook (food), and Psionics (psionic crystals)."
    },
    "bioforge": {
      "name": "Bioforge",
      "icon": "🧬",
      "color": "#44ffaa",
      "type": "production",
      "desc": "Craft armor and brew serums from creature parts. Use Bioforge Stations in the Bio-Lab.",
      "trains": "Craft items at Bioforge Stations.",
      "category": "Production",
      "needs": ["xenobotany"],
      "feeds": ["nano", "tesla", "void"],
      "feedDesc": "Craft armor sets and brew combat serums for all combat styles"
    },
    "circuitry": {
      "name": "Circuitry",
      "icon": "🔧",
      "color": "#ffaa44",
      "type": "production",
      "desc": "Smelt ores into bars and forge weapons, tools, and gadgets. Use Smelting Furnaces in the Bio-Lab.",
      "trains": "Smelt bars and craft equipment at Smelting Furnaces.",
      "category": "Production",
      "needs": ["astromining"],
      "feeds": ["nano", "tesla", "void"],
      "feedDesc": "Forge weapons and tools for all combat styles"
    },
    "xenocook": {
      "name": "Xenocook",
      "icon": "🍳",
      "color": "#ff4488",
      "type": "production",
      "desc": "Cook alien ingredients into healing food and combat buff meals. Use Xenocook Ranges in the Bio-Lab.",
      "trains": "Cook food at Xenocook Ranges.",
      "category": "Production",
      "needs": ["xenobotany"],
      "feeds": ["nano", "tesla", "void"],
      "feedDesc": "Cook healing food and combat buff meals for all combat styles"
    },
    "psionics": {
      "name": "Neural Engineering",
      "icon": "🧠",
      "color": "#ff44ff",
      "type": "prestige",
      "desc": "Advanced crafting using neural tissue from deep-space organisms. Produces psi-weave gear and power cores.",
      "trains": "Process neural materials at the Neural Processor.",
      "category": "Prestige",
      "locked": true,
      "lockText": "Complete the Neural Awakening quest chain.",
      "needs": ["nano", "tesla", "void", "circuitry"],
      "feedDesc": "Boss drops and metal bars feed into psi-weave gear and neural consumable crafting."
    },
    "chronomancy": {
      "name": "Quantum Synthesis",
      "icon": "⏳",
      "color": "#44ffff",
      "type": "prestige",
      "desc": "Transmute lower ores into higher-tier bars and brew temporal elixirs. Shortcuts material progression.",
      "trains": "Transmute materials at the Quantum Synthesizer.",
      "category": "Prestige",
      "softGate": true,
      "softGateText": "Requires Level 10 in any combat skill.",
      "needs": ["astromining", "bioforge"],
      "feedDesc": "Transmute ores to skip tiers and synthesize rare materials. Needs Bioforge catalysts at high levels."
    },
    "signal_archaeology": {
      "name": "Signal Archaeology",
      "icon": "📡",
      "color": "#44ddff",
      "type": "exploration",
      "desc": "Scan for and decode ancient signal fragments scattered across all areas. Higher levels unlock rarer fragment tiers and powerful protocol buffs.",
      "trains": "Collect signal fragments in scan mode and decode protocols at Decoder Terminals.",
      "category": "Exploration",
      "feeds": ["entropy_engineering", "dimensional_weaving"],
      "feedDesc": "Decoded protocols buff entropy yield and reveal hidden thread anchors. Echo data from entropy scans fuels fragment processing."
    },
    "entropy_engineering": {
      "name": "Entropy Engineering",
      "icon": "🔥",
      "color": "#ff6644",
      "type": "deconstruction",
      "desc": "Scan enemies to learn their weaknesses and deconstruct items into entropic materials. Mastering an enemy type grants permanent combat bonuses.",
      "trains": "Entropy-scan enemies and deconstruct items at Entropy Forges.",
      "category": "Exploration",
      "feeds": ["signal_archaeology", "dimensional_weaving"],
      "feedDesc": "Scans produce echo data for Signal Archaeology. Deconstruction yields thread filaments for Dimensional Weaving."
    },
    "dimensional_weaving": {
      "name": "Dimensional Weaving",
      "icon": "🌀",
      "color": "#aa66ff",
      "type": "construction",
      "desc": "Gather thread filaments from dimensional anchors and weave spatial constructs — snares, shields, and teleport folds.",
      "trains": "Gather thread anchors across all areas and weave constructs at Dimensional Looms.",
      "category": "Exploration",
      "feeds": ["entropy_engineering", "signal_archaeology"],
      "feedDesc": "Expired constructs yield entropic residue. High-level protocols open portable decoding stations."
    }
  },
